---
layout: layouts/base.njk
---

{% set seriesData = allSeries[seriesId] %}
{% set brandData = allBrands[seriesData.brand] %}

<article>
  {# Breadcrumb #}
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <ol class="flex items-center gap-2 text-sm text-gray-500">
      <li><a href="/{{ lang }}/" class="hover:text-brand">{{ "首页" if lang == "zh" else "Home" }}</a></li>
      <li class="text-gray-300">/</li>
      <li><a href="/{{ lang }}/brands/" class="hover:text-brand">{{ "品牌" if lang == "zh" else "Brands" }}</a></li>
      <li class="text-gray-300">/</li>
      <li><a href="/{{ lang }}/brands/{{ seriesData.brand }}/" class="hover:text-brand">{{ brandData.name | localize(lang) }}</a></li>
      <li class="text-gray-300">/</li>
      <li class="text-brand font-medium">{{ seriesData.name | localize(lang) }}</li>
    </ol>
  </nav>

  {# Hero #}
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col lg:flex-row gap-8">
      {# Image Gallery #}
      <div class="lg:w-1/2">
        <div class="bg-gradient-to-br from-gray-100 to-gray-200 rounded-2xl aspect-[4/3] flex items-center justify-center">
          <div class="text-center">
            <span class="text-6xl">🎱</span>
            <p class="mt-4 text-gray-400 text-sm">{{ "产品图片" if lang == "zh" else "Product Image" }}</p>
          </div>
        </div>
        {% if seriesData.images | length > 1 %}
        <div class="flex gap-3 mt-4">
          {% for img in seriesData.images %}
          <div class="w-20 h-20 bg-gray-100 rounded-lg flex items-center justify-center cursor-pointer hover:ring-2 hover:ring-accent">
            <span class="text-2xl">🎱</span>
          </div>
          {% endfor %}
        </div>
        {% endif %}
      </div>

      {# Info #}
      <div class="lg:w-1/2">
        <span class="tag mb-3">{{ seriesData.category | localize(lang) }}</span>
        <h1 class="text-3xl lg:text-4xl font-extrabold text-brand mb-3">{{ seriesData.name | localize(lang) }}</h1>
        <p class="text-2xl font-bold text-accent mb-6">${{ seriesData.price_range.min }} - ${{ seriesData.price_range.max }}</p>

        <div class="space-y-4 mb-8">
          <p class="text-gray-600 leading-relaxed">{{ seriesData.suitable_for | localize(lang) }}</p>
        </div>

        {# Highlights #}
        <div class="bg-green-50 rounded-xl p-5 mb-6">
          <h3 class="font-semibold text-green-800 mb-3">{{ "核心亮点" if lang == "zh" else "Key Highlights" }}</h3>
          <ul class="space-y-2">
            {% for h in seriesData.highlights[lang] %}
            <li class="flex items-start gap-2 text-sm text-green-700">
              <svg class="w-4 h-4 text-green-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              {{ h }}
            </li>
            {% endfor %}
          </ul>
        </div>

        {# Buy Links #}
        {% if seriesData.buy_links %}
        <div class="flex flex-wrap gap-3">
          {% for link in seriesData.buy_links %}
          <a href="{{ link.url }}" target="_blank" rel="noopener nofollow" class="btn-accent text-sm">
            {{ "购买" if lang == "zh" else "Buy" }} @ {{ link.platform }}
          </a>
          {% endfor %}
        </div>
        {% endif %}
      </div>
    </div>
  </section>

  {# Specs Table #}
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h2 class="section-title">{{ "详细参数" if lang == "zh" else "Specifications" }}</h2>
    <div class="mt-6 bg-white rounded-xl border border-gray-100 overflow-hidden">
      <table class="spec-table">
        <tr>
          <th>{{ "前节选项" if lang == "zh" else "Shaft Options" }}</th>
          <td>{{ seriesData.shaft_options | join(", ") }}</td>
        </tr>
        <tr>
          <th>{{ "接牙" if lang == "zh" else "Joint" }}</th>
          <td>{{ seriesData.joint }}</td>
        </tr>
        {% if seriesData.wrap_options | length %}
        <tr>
          <th>{{ "握把" if lang == "zh" else "Wrap" }}</th>
          <td>{{ seriesData.wrap_options | join(", ") }}</td>
        </tr>
        {% endif %}
        <tr>
          <th>{{ "重量" if lang == "zh" else "Weight" }}</th>
          <td>{{ seriesData.weight_range }}</td>
        </tr>
        <tr>
          <th>{{ "后把材质" if lang == "zh" else "Butt Material" }}</th>
          <td>{{ seriesData.butt_materials | join(", ") }}</td>
        </tr>
      </table>
    </div>
  </section>

  {# Review #}
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h2 class="section-title">{{ "深度点评" if lang == "zh" else "In-Depth Review" }}</h2>
    <div class="mt-6 prose prose-gray max-w-none">
      <p class="text-gray-600 leading-relaxed text-lg">{{ seriesData.review | localize(lang) }}</p>
    </div>
  </section>

  {# Back to Brand #}
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <a href="/{{ lang }}/brands/{{ seriesData.brand }}/" class="btn-primary">
      ← {{ "返回" if lang == "zh" else "Back to" }} {{ brandData.name | localize(lang) }}
    </a>
  </section>
</article>
